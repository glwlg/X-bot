# 请复制本文件为 .env 后再填写。
# 不要把真实密钥提交到版本库。

# Telegram Bot Token；留空表示不启用 Telegram 平台。
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN_HERE"

# Discord Bot Token；留空表示不启用 Discord 平台。
DISCORD_BOT_TOKEN="YOUR_DISCORD_BOT_TOKEN_HERE"

# 钉钉 Stream 模式 Client ID；留空表示不启用 DingTalk 平台。
DINGTALK_CLIENT_ID=""

# 钉钉 Stream 模式 Client Secret；需与 DINGTALK_CLIENT_ID 配套。
DINGTALK_CLIENT_SECRET=""

# 日志级别；常用值为 DEBUG / INFO / WARNING / ERROR。
LOG_LEVEL="INFO"

# 模型配置文件路径；留空时默认使用 config/models.json。
# 首次使用时请先从 config/models.example.json 复制出 config/models.json。
MODELS_CONFIG_PATH=""

# 单次请求内 agent 最多允许的工具回合数。
AI_TOOL_MAX_TURNS="20"

# 单次工具执行的默认超时时间，单位秒。
AI_TOOL_EXEC_TIMEOUT_SEC="420"

# 完全重复的工具调用达到该次数后触发重复保护。
AI_TOOL_REPEAT_GUARD="3"

# 同一工具在单次请求中最多允许被调用的次数。
AI_TOOL_MAX_CALLS_PER_TOOL="10"

# 语义上近似重复的工具调用达到该次数后触发保护。
AI_TOOL_SEMANTIC_REPEAT_GUARD="3"

# 旧式 extension/skill 包装执行超时时间，单位秒。
EXTENSION_EXEC_TIMEOUT_SEC="600"

# SearXNG 服务地址；本地开发或非 compose 场景下需要手动设置。
SEARXNG_URL=""

# 是否启用 SearXNG 结果重排与过滤。
SEARXNG_SEARCH_RERANK_ENABLED="true"

# 全局搜索结果域名白名单；留空表示不限制。
SEARXNG_SEARCH_ALLOWLIST=""

# 全局默认搜索结果域名黑名单。
SEARXNG_SEARCH_BLOCKLIST_DEFAULT=""

# 通用搜索的默认分类。
SEARXNG_SEARCH_GENERAL_CATEGORIES="general"

# 通用搜索的默认时间范围；留空表示不限制。
SEARXNG_SEARCH_GENERAL_TIME_RANGE=""

# 通用搜索优先使用的搜索引擎；留空表示使用服务端默认配置。
SEARXNG_SEARCH_GENERAL_ENGINES=""

# 通用搜索的域名白名单。
SEARXNG_SEARCH_GENERAL_ALLOWLIST=""

# 通用搜索的域名黑名单。
SEARXNG_SEARCH_GENERAL_BLOCKLIST=""

# 通用搜索是否严格限制在 allowlist 范围内。
SEARXNG_SEARCH_GENERAL_STRICT_SOURCES="false"

# 天气类搜索的默认分类。
SEARXNG_SEARCH_WEATHER_CATEGORIES="general"

# 天气类搜索的默认时间范围。
SEARXNG_SEARCH_WEATHER_TIME_RANGE="day"

# 天气类搜索优先保留的站点域名。
SEARXNG_SEARCH_WEATHER_ALLOWLIST="weather.com.cn,iqair.cn,nmc.cn,cma.cn"

# 天气类搜索优先使用的搜索引擎。
SEARXNG_SEARCH_WEATHER_ENGINES="google,bing"

# 天气类搜索是否严格限制在 allowlist 范围内。
SEARXNG_SEARCH_WEATHER_STRICT_SOURCES="false"

# 天气类搜索的额外黑名单域名。
SEARXNG_SEARCH_WEATHER_BLOCKLIST=""

# 新闻类搜索的默认分类。
SEARXNG_SEARCH_NEWS_CATEGORIES="news"

# 新闻类搜索的默认时间范围。
SEARXNG_SEARCH_NEWS_TIME_RANGE="day"

# 新闻类搜索优先使用的搜索引擎。
SEARXNG_SEARCH_NEWS_ENGINES="google,bing"

# 新闻类搜索优先保留的站点域名。
SEARXNG_SEARCH_NEWS_ALLOWLIST="xinhuanet.com,people.com.cn,cctv.com,reuters.com"

# 新闻类搜索的额外黑名单域名。
SEARXNG_SEARCH_NEWS_BLOCKLIST=""

# 新闻类搜索是否严格限制在 allowlist 范围内。
SEARXNG_SEARCH_NEWS_STRICT_SOURCES="false"

# 技术类搜索的默认分类。
SEARXNG_SEARCH_TECH_CATEGORIES="it"

# 技术类搜索的默认时间范围；留空表示不限制。
SEARXNG_SEARCH_TECH_TIME_RANGE=""

# 技术类搜索优先使用的搜索引擎。
SEARXNG_SEARCH_TECH_ENGINES="google,bing"

# 技术类搜索优先保留的站点域名。
SEARXNG_SEARCH_TECH_ALLOWLIST="docs.python.org,developer.mozilla.org,stackoverflow.com,github.com"

# 技术类搜索的额外黑名单域名。
SEARXNG_SEARCH_TECH_BLOCKLIST=""

# 技术类搜索是否严格限制在 allowlist 范围内。
SEARXNG_SEARCH_TECH_STRICT_SOURCES="false"

# 管理员用户 ID 列表，多个用逗号分隔；为空时默认开放模式。
ADMIN_USER_IDS=""

# 宿主机上的发布暂存目录绝对路径；容器内外必须是同一路径。
X_DEPLOYMENT_STAGING_PATH=""

# 部署完成后用于生成访问地址的服务器 IP 或域名；留空则尽量自动推断。
SERVER_IP=""

# 是否启用 heartbeat 周期任务。
HEARTBEAT_ENABLED="true"

# heartbeat 执行频率，例如 30m、1h。
HEARTBEAT_EVERY="30m"

# heartbeat 默认关注目标；常用值为 last。
HEARTBEAT_TARGET="last"

# heartbeat 允许主动运行的时间窗口开始时间。
HEARTBEAT_ACTIVE_START="08:00"

# heartbeat 允许主动运行的时间窗口结束时间。
HEARTBEAT_ACTIVE_END="22:00"

# heartbeat 使用的时区；留空时按系统时区。
HEARTBEAT_TIMEZONE=""

# heartbeat 主循环 tick 间隔，单位秒。
HEARTBEAT_TICK_SEC="30"

# 无待办事项时是否抑制 HEARTBEAT_OK 类消息。
HEARTBEAT_SUPPRESS_OK="true"

# heartbeat 用户级锁超时时间，单位秒。
HEARTBEAT_LOCK_TIMEOUT_SEC="20"

# heartbeat 模式；当前常用值为 readonly。
HEARTBEAT_MODE="readonly"

# readonly 模式下是否允许把任务派发给 worker。
HEARTBEAT_READONLY_DISPATCH="true"

# 可恢复终止错误的自动恢复最大尝试次数。
AUTO_RECOVERY_MAX_ATTEMPTS="3"

# Worker 工作区根目录；留空表示走默认路径。
USERLAND_ROOT=""

# Manager/Worker 共享 dispatch 队列根目录；留空表示使用 data/system/dispatch。
MANAGER_DISPATCH_ROOT=""

# Worker 默认后端标识。
WORKER_DEFAULT_BACKEND="core-agent"

# 默认 worker 的逻辑 ID。
WORKER_KERNEL_ID="worker-main"

# Worker 进程 claim 任务时写入的执行身份标识。
WORKER_KERNEL_IDENTITY="x-bot-worker"

# Worker 轮询队列的时间间隔，单位秒。
WORKER_KERNEL_POLL_SEC="1.0"

# 单个 worker 进程允许的最大并发任务数。
WORKER_KERNEL_MAX_CONCURRENCY="2"

# 默认 worker program 的 program_id。
WORKER_DEFAULT_PROGRAM_ID="default-worker"

# 默认 worker program 的版本号。
WORKER_DEFAULT_PROGRAM_VERSION="v1"

# worker program 产物根目录；留空表示使用默认路径。
WORKER_PROGRAMS_ROOT=""

# 是否启用 manager 侧 worker 结果 relay。
WORKER_RESULT_RELAY_ENABLED="true"

# worker 结果 relay 的轮询间隔，单位秒。
WORKER_RESULT_RELAY_TICK_SEC="2"

# Manager 侧默认使用的 coding backend。
CODING_BACKEND_DEFAULT="codex"

# coding backend 单次执行超时时间，单位秒。
CODING_BACKEND_TIMEOUT_SEC="900"

# 调用 Codex 的命令名或可执行路径。
CODING_BACKEND_CODEX_COMMAND="codex"

# 调用 Gemini CLI 的命令名或可执行路径。
CODING_BACKEND_GEMINI_COMMAND="gemini-cli"

# Codex 调用参数模板；`{instruction}` 会被替换成实际任务说明。
CODING_BACKEND_CODEX_ARGS_TEMPLATE="exec --model gpt-5.3-codex -c model_reasoning_effort=\"xhigh\" --sandbox workspace-write {instruction}"

# Gemini CLI 调用参数模板；`{instruction}` 会被替换成实际任务说明。
CODING_BACKEND_GEMINI_ARGS_TEMPLATE="--model gemini-3.1-pro --prompt {instruction}"

# 是否跳过 Codex 的 git 仓库检查。
CODING_BACKEND_CODEX_AUTO_SKIP_GIT_REPO_CHECK="true"

# skill_manager 规格说明文件路径。
SKILL_MANAGER_SPEC_PATH="skills/builtin/skill_manager/SKILL_SPEC.md"

# GitHub Token；software delivery 需要访问 GitHub 时使用。
GITHUB_TOKEN=""

# 允许 software delivery 访问的 GitHub 仓库白名单，多个可用逗号分隔。
GITHUB_ALLOWED_REPOS=""

# software delivery 默认使用的 GitHub owner。
GITHUB_DEFAULT_OWNER=""

# software delivery 默认使用的 GitHub repo。
GITHUB_DEFAULT_REPO=""

# Manager 软件交付工作区根目录。
DEV_WORKSPACE_ROOT=""

# Manager 软件交付任务与日志根目录。
DEV_TASKS_ROOT=""

# software delivery 验证阶段超时时间，单位秒。
DEV_VALIDATION_TIMEOUT_SEC="1800"

# Core chat 的执行策略；可选 worker_only / worker_preferred / orchestrator。
CORE_CHAT_EXECUTION_MODE="worker_only"

# 当 core chat 选择派发给 worker 时优先使用的 backend。
CORE_CHAT_WORKER_BACKEND="core-agent"

# 核心层原语默认视为只读保护的路径，多个以逗号分隔。
KERNEL_PROTECTED_PATHS="src/core,src/services,src/handlers"
